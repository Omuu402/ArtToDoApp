<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_task_list.xml — shared by ALL THREE fragments (Ongoing, Upcoming, Finished).

    Structure:
    CoordinatorLayout
    ├── RecyclerView       (scrollable list of task cards)
    ├── LinearLayout       (empty-state message shown when list is empty)
    └── FloatingActionButton (FAB: opens Add Task dialog)

    The Fragment's Kotlin code toggles RecyclerView/layoutEmpty visibility
    based on whether the task list is empty.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_white">

    <!-- ── Task List ────────────────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- ── Empty State ──────────────────────────────────────────────────────── -->
    <!--
        Shown when there are no tasks. Centred on screen.
        Each fragment's Kotlin code sets the icon and message via code,
        or you can hardcode them here per layout copy.
    -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivEmptyIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_brush"
            android:alpha="0.3"
            android:contentDescription="No tasks" />

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="No works here yet"
            android:textColor="@color/warm_grey"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tap + to add your first project"
            android:textColor="@color/warm_grey"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ── FAB: Add Task ────────────────────────────────────────────────────── -->
    <!--
        Positioned bottom-right. Tapping it opens AddEditTaskDialog in ADD mode.
        The icon is a simple "+" (ic_add vector asset).
    -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Add new work"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/charcoal"
        app:tint="@color/cream_white"
        app:elevation="4dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
