<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_add_edit_task.xml — layout for the Add/Edit BottomSheetDialogFragment.

    Structure:
    NestedScrollView (allows form to scroll if screen is small)
    └── LinearLayout (vertical form)
        ├── Title ("Add New Work" or "Edit Work")
        ├── Title field
        ├── Medium field
        ├── Description field (multiline)
        ├── Due Date field
        ├── Status spinner (Ongoing / Upcoming / Finished)
        └── [Cancel] [Save Work] buttons
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_top_sheet"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Drag handle indicator (optional visual cue for bottom sheet) -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@color/soft_border"
            android:backgroundTint="@color/warm_grey" />

        <!-- ── Dialog Title ────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add New Work"
            android:textSize="18sp"
            android:textColor="@color/charcoal"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- ── Title Field ────────────────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Title *"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Medium / Style Field ───────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Medium / Style (e.g. Oil on canvas)"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Description Field ─────────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Description / Notes"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences|textMultiLine"
                android:minLines="3"
                android:maxLines="6"
                android:gravity="top" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Due Date Field ────────────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Due Date (YYYY-MM-DD)"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDueDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Status Spinner ─────────────────────────────────────────────── -->
        <!--
            Label above the spinner
        -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textSize="12sp"
            android:textColor="@color/warm_grey"
            android:layout_marginBottom="4dp" />

        <!--
            Spinner populated by ArrayAdapter in AddEditTaskDialog.kt
            using the R.array.status_options string array from strings.xml
        -->
        <Spinner
            android:id="@+id/spinnerStatus"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/spinner_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- ── Action Buttons ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- Cancel -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Cancel"
                android:textColor="@color/charcoal"
                app:strokeColor="@color/soft_border" />

            <!-- Save -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Save Work"
                android:backgroundTint="@color/charcoal"
                android:textColor="@color/cream_white" />

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
