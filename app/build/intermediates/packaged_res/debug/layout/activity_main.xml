<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — root layout for MainActivity.

    Structure:
    CoordinatorLayout
    ├── AppBarLayout (holds the Toolbar)
    ├── FragmentContainerView (NavHostFragment — swaps between the 3 tab fragments)
    └── BottomNavigationView (3 tabs: Ongoing | Upcoming | Finished)

    CoordinatorLayout is used so the BottomNav and AppBar can coordinate
    with scrolling content (e.g., hiding on scroll in the future).
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_white">

    <!-- ── Top App Bar ──────────────────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/cream_white"
        app:elevation="0dp">

        <!--
            MaterialToolbar: displays the current fragment's label as the title.
            The title text is updated automatically by setupActionBarWithNavController().
        -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="My Canvas"
            app:titleTextColor="@color/charcoal"
            app:titleTextAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Fragment Container ───────────────────────────────────────────────── -->
    <!--
        NavHostFragment: the "frame" where Ongoing / Upcoming / Finished fragments
        are swapped in and out by the Navigation Component.

        app:defaultNavHost="true" means this NavHost intercepts the back button.
        app:navGraph points to our navigation/nav_graph.xml file.
    -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <!-- ── Bottom Navigation ────────────────────────────────────────────────── -->
    <!--
        BottomNavigationView: renders 3 tabs from @menu/bottom_nav_menu.
        setupWithNavController() links tab selection to the NavController automatically.
    -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/cream_white"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:elevation="4dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
