<?xml version="1.0" encoding="utf-8"?>
<!--
    rounded_top_sheet.xml — background for the BottomSheetDialogFragment layout.

    The dialog_add_edit_task.xml root view uses this as its background
    to get rounded top corners without relying solely on the theme style.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FAFAF7" />
    <corners
        android:topLeftRadius="16dp"
        android:topRightRadius="16dp"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp" />
</shape>
